# Local development (copy to .env)
DATABASE_URL=sqlite:///./dela_langa.db
SECRET_KEY=change-this-to-a-long-random-string
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=uploads

# Email alerts — set EMAIL_ENABLED=true and configure SMTP to send real emails
# When false, emails are logged to the console (demo mode)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=noreply@delalanga.mw
SMTP_FROM_NAME=Dela Langa
